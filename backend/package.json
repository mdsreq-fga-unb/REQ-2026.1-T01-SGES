{
  "name": "sges",
  "version": "1.0.0",
  "description": "Projeto Requisitos de Software 2026.1",
  "main": "index.js",
  "scripts": {
    "test": "./run-tests.sh",
    "build": "tsup",
    "dev": "tsx watch --env-file=./env/.env.dev ./src/server.ts",
    "local": "tsx watch --env-file=./env/.env.local ./src/server.ts",
    "migration:generate": "export $(cat ./env/.env.dev | xargs) && cross-env NODE_ENV=dev tsx ./node_modules/typeorm/cli.js migration:generate -d ./src/infra/orm/datasource.ts",
    "migration:revert": "export $(cat ./env/.env.dev | xargs) && cross-env NODE_ENV=dev tsx ./node_modules/typeorm/cli.js migration:revert -d ./src/infra/orm/datasource.ts",
    "seed": "export $(cat ./env/.env.dev | xargs) && tsx ./src/infra/orm/seed.ts",
    "lint": "tsc --noEmit && eslint ./src/ ./tests/ --no-error-on-unmatched-pattern",
    "lint:fix": "npm run lint -- --fix"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.11",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rsdi": "^3.0.4",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^7.1.5",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "^3.2.4"
  }
}
